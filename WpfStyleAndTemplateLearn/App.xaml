<Application x:Class="WpfStyleAndTemplateLearn.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfStyleAndTemplateLearn"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontFamily" Value="Malgun Gothic" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontFamily" Value="Malgun Gothic" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="BorderBrush" Value="#9CA3AF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ToggleIconButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="220" />
            <Setter Property="Height" Value="64" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontFamily" Value="Malgun Gothic" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Background" Value="#E5E7EB" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="32"
                                Padding="18,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Viewbox Width="20"
                                         Height="20"
                                         VerticalAlignment="Center">
                                    <Grid>
                                        <Path x:Name="OffIcon"
                                              Fill="#111827"
                                              Data="M 0,0 L 0,18 L 14,9 Z" />
                                        <Path x:Name="OnIcon"
                                              Fill="#111827"
                                              Visibility="Collapsed"
                                              Data="M 0,0 H 4 V 18 H 0 Z M 8,0 H 12 V 18 H 8 Z" />
                                    </Grid>
                                </Viewbox>

                                <ContentPresenter Grid.Column="1"
                                                  Margin="12,0,0,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#D1D5DB" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#9CA3AF" />
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#BFDBFE" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#60A5FA" />
                                <Setter TargetName="OffIcon" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="OnIcon" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
