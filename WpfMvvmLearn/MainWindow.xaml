<Window x:Class="WpfMvvmLearn.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WpfMvvmLearn.Behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:WpfMvvmLearn.ViewModels"
        mc:Ignorable="d"
        Title="WPF MVVM Learn"
        Width="900"
        Height="600"
        Background="#F3F4F6">
    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <Grid Margin="24">
        <Border Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20">
            <TabControl>
                <TabItem Header="과제 1. 카운터 앱">
                    <Grid DataContext="{Binding Counter}"
                          Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="28"
                                       FontWeight="Bold"
                                       Text="카운터 앱 MVVM" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#4B5563"
                                       Text="코드 비하인드 없이 ViewModel의 Count 속성과 IncrementCommand를 바인딩합니다." />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,28,0,0"
                                Padding="24"
                                HorizontalAlignment="Left"
                                Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="18"
                                           Foreground="#6B7280"
                                           Text="현재 숫자" />
                                <TextBlock Margin="0,12,0,20"
                                           HorizontalAlignment="Center"
                                           FontSize="56"
                                           FontWeight="Bold"
                                           Text="{Binding Count}" />
                                <Button Width="180"
                                        Height="44"
                                        Command="{Binding IncrementCommand}"
                                        Content="1 증가" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="과제 2. 로그인 폼">
                    <Grid DataContext="{Binding Login}"
                          Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="28"
                                       FontWeight="Bold"
                                       Text="로그인 폼 MVVM" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#4B5563"
                                       Text="UserName, Password, LoginCommand를 바인딩하고 두 입력값이 모두 있을 때만 버튼을 활성화합니다." />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,28,0,0"
                                Padding="24"
                                HorizontalAlignment="Left"
                                Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel Width="320">
                                <TextBlock Margin="0,0,0,8"
                                           FontWeight="SemiBold"
                                           Text="아이디" />
                                <TextBox Height="36"
                                         Margin="0,0,0,16"
                                         Padding="10,6"
                                         Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,0,0,8"
                                           FontWeight="SemiBold"
                                           Text="비밀번호" />
                                <PasswordBox Height="36"
                                             Margin="0,0,0,20"
                                             Padding="10,6"
                                             behaviors:PasswordBoxAssistant.BindPassword="True"
                                             behaviors:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Button Height="42"
                                        Command="{Binding LoginCommand}"
                                        Content="로그인" />

                                <Border Margin="0,20,0,0"
                                        Padding="14"
                                        Background="#FFFFFF"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <TextBlock Foreground="#374151"
                                               Text="{Binding LoginStatus}" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="과제 3. To-Do 리스트">
                    <Grid Margin="20">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="18"
                                   Foreground="#6B7280"
                                   Text="To-Do 리스트 MVVM은 다음 단계에서 구현합니다." />
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
