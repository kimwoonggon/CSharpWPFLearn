<Window x:Class="WpfDataBindingLearn.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfDataBindingLearn"
        mc:Ignorable="d"
        Title="WPF Data Binding" Height="620" Width="520">
    <Window.Resources>
        <local:PercentageConverter x:Key="PercentageConverter" />
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Border Width="320"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="#D4D4D4"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Margin="0,0,0,16"
                           FontSize="22"
                           FontWeight="Bold"
                           Text="데이터 바인딩" />

                <TextBlock Margin="0,0,0,6"
                           Text="이름 입력" />
                <TextBox Margin="0,0,0,16"
                         Padding="8"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,0,0,6"
                           Text="실시간 반영 결과" />
                <Label Padding="8"
                       Background="#FAFAFA"
                       BorderBrush="#D4D4D4"
                       BorderThickness="1"
                       Content="{Binding Name}" />

                <TextBlock Margin="0,20,0,6"
                           FontWeight="Bold"
                           Text="상품 목록" />
                <ListBox Height="140"
                         Margin="0,0,0,12"
                         ItemsSource="{Binding Products}" />

                <Button Height="36"
                        Click="AddProductButton_Click"
                        Content="새 상품 추가" />

                <TextBlock Margin="0,20,0,6"
                           FontWeight="Bold"
                           Text="퍼센트 변환기" />
                <Slider x:Name="PercentSlider"
                        Minimum="0"
                        Maximum="100"
                        Value="25"
                        TickFrequency="10"
                        IsSnapToTickEnabled="False" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="{Binding ElementName=PercentSlider, Path=Value, Converter={StaticResource PercentageConverter}}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
