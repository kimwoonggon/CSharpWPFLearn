<Window x:Class="WpfAnimationAndCustomControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAnimationAndCustomControl"
        xmlns:controls="clr-namespace:WpfAnimationAndCustomControl.Controls"
        mc:Ignorable="d"
        Title="WPF Animation And Custom Control"
        Width="900"
        Height="600"
        Background="#F3F4F6">
    <Window.Resources>
        <QuadraticEase x:Key="EaseOut" EasingMode="EaseOut" />
    </Window.Resources>
    <Grid Margin="24">
        <Border Background="White"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20">
            <TabControl>
                <!-- ==================== 과제 1. 버튼 색상 애니메이션 ==================== -->
                <TabItem Header="과제 1. 버튼 색상 애니메이션">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="28"
                                       FontWeight="Bold"
                                       Text="버튼 색상 애니메이션" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#4B5563"
                                       Text="마우스를 올리면 배경색이 서서히 변하고, 벗어나면 원래 색으로 돌아옵니다. (ColorAnimation + EventTrigger)" />
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Margin="0,28,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <!-- 애니메이션 대상 버튼 -->
                            <Button Width="260"
                                    Height="60"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Content="마우스를 올려 보세요"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ButtonBorder"
                                                CornerRadius="10"
                                                Padding="20,12">
                                            <Border.Background>
                                                <SolidColorBrush x:Name="ButtonBrush" Color="#3B82F6" />
                                            </Border.Background>
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <EventTrigger RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="ButtonBrush"
                                                                        Storyboard.TargetProperty="Color"
                                                                        To="#EF4444"
                                                                        Duration="0:0:0.4" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="ButtonBrush"
                                                                        Storyboard.TargetProperty="Color"
                                                                        To="#3B82F6"
                                                                        Duration="0:0:0.4" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock Margin="0,24,0,0"
                                       HorizontalAlignment="Center"
                                       Foreground="#6B7280"
                                       FontSize="14"
                                       Text="파란색(#3B82F6) → 빨간색(#EF4444) → 파란색" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ==================== 과제 2. 커스텀 컨트롤 ==================== -->
                <TabItem Header="과제 2. 커스텀 컨트롤">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="28"
                                       FontWeight="Bold"
                                       Text="커스텀 ProgressBar (CustomControl)" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#4B5563"
                                       Text="Control을 상속한 CustomControl로 만든 사각형 ProgressBar입니다. Value 의존성 속성(0~100)에 따라 사각형 너비가 변합니다." />
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Margin="0,28,0,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch">

                            <!-- 커스텀 ProgressBar 컨트롤 -->
                            <controls:RectangleProgressBar x:Name="CustomProgressBar"
                                                           Height="36"
                                                           Margin="0,0,0,20"
                                                           Value="{Binding ElementName=ValueSlider, Path=Value}" />

                            <!-- 값 조절용 Slider -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="14"
                                           Foreground="#4B5563"
                                           Text="Value: " />
                                <Slider x:Name="ValueSlider"
                                        Width="400"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="35"
                                        VerticalAlignment="Center"
                                        IsSnapToTickEnabled="True"
                                        TickFrequency="1" />
                                <TextBlock VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="{Binding ElementName=ValueSlider, Path=Value, StringFormat={}{0:F0}%}" />
                            </StackPanel>

                            <!-- BarBrush 색상 변경 버튼 -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,20,0,0">
                                <Button Content="Blue" Margin="4" Padding="16,6" Click="OnBlueClick" />
                                <Button Content="Green" Margin="4" Padding="16,6" Click="OnGreenClick" />
                                <Button Content="Red" Margin="4" Padding="16,6" Click="OnRedClick" />
                            </StackPanel>

                            <TextBlock Margin="0,16,0,0"
                                       HorizontalAlignment="Center"
                                       Foreground="#6B7280"
                                       FontSize="13"
                                       Text="Slider를 움직이면 Value DP가 바뀌고, 사각형 너비가 실시간으로 변합니다." />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ==================== 과제 3. UI 상태 애니메이션 ==================== -->
                <TabItem Header="과제 3. UI 상태 애니메이션">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="28"
                                       FontWeight="Bold"
                                       Text="UI 상태 애니메이션" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#4B5563"
                                       Text="ToggleButton의 IsChecked 상태에 따라 TextBox가 나타나거나 사라집니다. (DataTrigger + DoubleAnimation Height)" />
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Margin="0,28,0,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">

                            <ToggleButton x:Name="ToggleBtn"
                                          Width="200"
                                          Height="44"
                                          FontSize="16"
                                          Content="텍스트 박스 열기"
                                          Cursor="Hand" />

                            <!-- Height 애니메이션 대상 TextBox -->
                            <TextBox x:Name="AnimatedTextBox"
                                     Width="400"
                                     Height="0"
                                     Margin="0,16,0,0"
                                     Padding="10"
                                     FontSize="14"
                                     Text="ToggleButton으로 나타나는 텍스트 박스입니다."
                                     VerticalScrollBarVisibility="Auto"
                                     ClipToBounds="True">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <!-- IsChecked = True → 높이 120으로 펼침 -->
                                            <DataTrigger Binding="{Binding ElementName=ToggleBtn, Path=IsChecked}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                             To="120"
                                                                             Duration="0:0:0.3"
                                                                             EasingFunction="{StaticResource EaseOut}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <!-- IsChecked = False로 돌아갈 때 → 높이 0으로 접힘 -->
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                                             To="0"
                                                                             Duration="0:0:0.3"
                                                                             EasingFunction="{StaticResource EaseOut}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <TextBlock Margin="0,16,0,0"
                                       HorizontalAlignment="Center"
                                       Foreground="#6B7280"
                                       FontSize="13"
                                       Text="ToggleButton을 클릭하면 TextBox가 부드럽게 나타나거나 사라집니다." />
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
